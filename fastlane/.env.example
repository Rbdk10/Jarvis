# Copy this to fastlane/.env (which is gitignored) and fill in your values.
# Get these from App Store Connect → Users and Access → Integrations → App Store Connect API.
ASC_KEY_ID=YOUR_KEY_ID
ASC_ISSUER_ID=YOUR_ISSUER_ID
# Absolute path to the downloaded .p8 private key (keep it OUTSIDE the repo):
ASC_KEY_PATH=/Users/anthoniedeklerk/.appstoreconnect/AuthKey_YOUR_KEY_ID.p8
