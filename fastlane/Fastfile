default_platform(:ios)

platform :ios do
  desc "Bump build number, archive, and upload to TestFlight"
  lane :beta do
    # In CI, create + unlock a temporary keychain and install the signing identity into
    # it. Without this, codesign blocks on a keychain-access prompt that a headless
    # runner can never answer — the build hangs forever at "Signing Jarvis.app".
    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )

    # XcodeGen is the source of truth for the project — regenerate before building.
    sh("cd .. && xcodegen generate")

    # Pre-ship guardrail: compile + launch the app in a simulator; abort the whole lane
    # (no upload) if it fails to build or crashes on launch. Keeps a broken build from
    # reaching TestFlight — applies whether the laptop OR the agent runs `fastlane beta`.
    sh("cd .. && bash tools/smoke_test.sh")

    # Fetch (or, on the very first run, create) ONE reusable signing identity from the
    # encrypted match vault — instead of minting a brand-new certificate every build.
    # THIS is what stops the "maximum number of certificates" wall: the cert is created
    # once, stored in the private vault repo, and reused by every build thereafter.
    match(
      type: "appstore",
      app_identifier: "com.agrisol.Jarvis",
      api_key: api_key,
      git_url: "https://github.com/AnthonieDeKlerk78/jarvis-match.git",
      readonly: true    # vault already seeded — fetch + install the stored identity, never create
    )

    # Next build number = one above the latest already on TestFlight.
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "com.agrisol.Jarvis"
    )
    increment_build_number(
      xcodeproj: "Jarvis.xcodeproj",
      build_number: (latest + 1).to_s
    )

    # Manual signing with the match profile (set AFTER xcodegen regenerated the project).
    # No -allowProvisioningUpdates → xcodebuild never creates a new certificate.
    profile_name = ENV["sigh_com.agrisol.Jarvis_appstore_profile-name"]
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Jarvis.xcodeproj",
      team_id: "6V4DVV45UP",
      code_sign_identity: "Apple Distribution",
      bundle_identifier: "com.agrisol.Jarvis",
      profile_name: profile_name
    )

    build_app(
      project: "Jarvis.xcodeproj",
      scheme: "Jarvis",
      export_method: "app-store",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: { "com.agrisol.Jarvis" => profile_name }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
