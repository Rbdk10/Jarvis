default_platform(:ios)

platform :ios do
  desc "Bump build number, archive, and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )

    # XcodeGen is the source of truth for the project — regenerate before building.
    sh("cd .. && xcodegen generate")

    # Pre-ship guardrail: compile + launch the app in a simulator; abort the whole lane
    # (no upload) if it fails to build or crashes on launch. Keeps a broken build from
    # reaching TestFlight — applies whether the laptop OR the agent runs `fastlane beta`.
    sh("cd .. && bash tools/smoke_test.sh")

    # Next build number = one above the latest already on TestFlight.
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "com.agrisol.Jarvis"
    )
    increment_build_number(
      xcodeproj: "Jarvis.xcodeproj",
      build_number: (latest + 1).to_s
    )

    # Pass App Store Connect auth to xcodebuild so -allowProvisioningUpdates can create
    # the distribution cert/profile on a headless CI runner (no signed-in Xcode account).
    # Locally these come from fastlane/.env; in CI from the workflow. Falls back to plain
    # provisioning updates if unset (e.g. a Mac with a signed-in account).
    auth_args =
      if ENV["ASC_KEY_PATH"] && ENV["ASC_KEY_ID"] && ENV["ASC_ISSUER_ID"]
        " -authenticationKeyPath #{ENV['ASC_KEY_PATH']}" \
        " -authenticationKeyID #{ENV['ASC_KEY_ID']}" \
        " -authenticationKeyIssuerID #{ENV['ASC_ISSUER_ID']}"
      else
        ""
      end

    build_app(
      project: "Jarvis.xcodeproj",
      scheme: "Jarvis",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates#{auth_args}"
      # NB: no export_xcargs — gym already injects -allowProvisioningUpdates + the auth
      # key into the export step, and passing them again trips
      # "xcodebuild: error: option '-authenticationKeyPath' may only be provided once".
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
